# ─────────────────────────────────────────────
#  Telegram Bot
# ─────────────────────────────────────────────

# Токен бота — получить у @BotFather командой /newbot
BOT_TOKEN=

# ID получателей заявок (через запятую, без пробелов)
# Узнать свой ID: написать боту @userinfobot
# Пример: 123456789,987654321
NOTIFY_IDS=

# Секретный токен для верификации вебхука (любая случайная строка)
# Сгенерировать: openssl rand -hex 32
WEBHOOK_SECRET=

# ─────────────────────────────────────────────
#  Домен и сервер
# ─────────────────────────────────────────────

# Ваш домен БЕЗ https:// (например: dvaplus.ru)
DOMAIN=

# Порт Node.js-сервера (nginx проксирует на него)
PORT=2250

# ─────────────────────────────────────────────
#  Панель управления
# ─────────────────────────────────────────────

# Пароль для входа в /admin (тот, что сейчас в server.js)
ADMIN_PASSWORD=Z1488Z
